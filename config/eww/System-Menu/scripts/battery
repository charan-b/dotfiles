#!/bin/sh

bat=$(acpi -b)
level=$(acpi -b|grep -o "[0-9]*%"|tr -d "%")

icon() {
    if [[ "$bat" == *"until"* ]]; then
        
        if [[ "$level" -ge "80" ]]; then
            echo "ΎΔπ ΪΑδρ "
            elif [[ "$level" -ge "40" ]]; then
            echo "ΎΔπ ΪΑδσ  "
        else
            echo "ΎΔπ ΪΑδς  "
        fi
    else
        if [[ "$level" -ge "80" ]]; then
            echo "ΪΑδρ "
            elif [[ "$level" -ge "40" ]]; then
            echo "ΪΑδσ  "
        else
            echo "ΪΑδς  "
        fi
    fi
}

class() {
    if [[ "$bat" == *"until"* ]]; then
        echo "ΎΔπ"
    else
        echo "ΎΚΑ "
    fi
}

if [[ $1 = "-l" ]]; then
    echo "${level}%"
elif [[ $1 == "-c" ]]; then
    class
elif [[ $1 = "-i" ]]; then
    icon
fi
