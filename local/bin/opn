#!/bin/sh

export NVIM_APPNAME="NvChad"

fzf_preview="(file -bL --mime-type {}|grep -iq 'text') && (bat --style=numbers --color=always {})\
  || dirname {} |xargs -I {} tree {} | head -200"

export FZF_DEFAULT_COMMAND='fd -Ha --base-directory ~ --type f \
  --exclude={"Applications/","Music/","*.srt","go/",".cache/",".var/",".local/",".mozilla/",".git/",".npm/"}'

open_file() {
    type=$(file --dereference --brief --mime-type "$file")
    echo $__term
    case "$type" in
        text/* | */x-shellscript | */json)
            if [ "$__term" != "hyp" ]; then
                [ -f "$file" ] && ${EDITOR} "$file"
            else
                [ -f "$file" ] && kitty --detach "${EDITOR}" "$file"
            fi
            ;;
        *)
            [ -f "$file" ] && setsid -f xdg-open "$file" >/dev/null 2>&1
            ;;
    esac
}
youtubelink() {
    if wl-paste | grep -q "youtube"; then
        notify-send "please wait Video is Loading.."
        mpv --no-terminal --quiet "$(wl-paste)"
    else
        notify-send "\"$(wl-paste)\" is Not a Link"
    fi
}

case "$1" in
    mpv)
        fd --type f . ~/Videos/ | fzf -m --with-nth=-3.. -d / | while read -r "file"; do
            [ -z "$file" ] || open_file "$file"
        done
        ;;
    youtube)
        youtubelink
        ;;
    scr)
        fd . | fzf -m --with-nth=-3.. -d / --preview "${fzf_preview}" --preview-window 'wrap' | xargs "$EDITOR"
        ;;
    *)
        __term="$1"
        if [ ! -f "$__term" ]; then
            fzf -m --with-nth=-3.. -d / --preview "${fzf_preview}" --preview-window 'down,wrap' --keep-right --bind 'change:first' --bind 'ctrl-/:change-preview-window(hidden|)' | while read -r "file"; do
                open_file "$file"
            done
        else
            xdg-open "$1"
        fi
        ;;
esac
